# Application Environment

# Options: development, production, test

NODE_ENV=development
PORT=3000

# Firebase Configuration

# These values can be found in your Firebase Project Settings -> Service Accounts -> Generate New Private Key

FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com

# Note: The private key should be a single line. The application handles converting '\n' characters.

FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEvQIBADANBgkqhkiG9w0BAQEFAASCBKcwggSjAgEAAoIBAQDCp...\n-----END PRIVATE KEY-----\n"

# Pinecone Vector Database

# Get these from your Pinecone console

PINECONE_API_KEY=your-pinecone-api-key
PINECONE_INDEX_NAME=brainvault-index

# LLM Configuration (Google Gemini)

# Get your API key from Google AI Studio

GEMINI_API_KEY=your-gemini-api-key

# Options: gemini, replicate

LLM_PROVIDER=gemini

# Application Limits & Safety

# Max requests per minute

RATE_LIMIT_MAX=100